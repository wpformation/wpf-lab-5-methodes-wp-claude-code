{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 1,
  "name": "wpf/lab-methods-table",
  "title": "Lab — Tableau 7 méthodes",
  "description": "Tableau comparatif des 7 méthodes WP × Claude Code. Contenu figé dans le plugin. Direction B Lab.",
  "category": "widgets",
  "icon": "editor-table",
  "keywords": ["lab", "methods", "table", "wpformation"],
  "supports": {
    "autoRegister": true,
    "align": ["full"]
  },
  "attributes": {
    "eyebrow":     { "type": "string", "label": "Eyebrow", "default": "// 02.benchmark · 7 méthodes · scoring 0—5", "autoGenerateControl": true },
    "titlePart1":  { "type": "string", "label": "Titre partie 1",     "default": "les 7 méthodes,", "autoGenerateControl": true },
    "titleViolet": { "type": "string", "label": "Titre mot violet",   "default": "scorées", "autoGenerateControl": true },
    "titlePart2":  { "type": "string", "label": "Titre partie 2",     "default": "sur", "autoGenerateControl": true },
    "titleAcid":   { "type": "string", "label": "Titre nombre acid",  "default": "5", "autoGenerateControl": true },
    "featuredRow": { "type": "number", "label": "N° ligne featured (1-7)", "default": 7, "autoGenerateControl": true }
  },
  "render": "file:./render.php",
  "style": "wpf-lab-blocks-style"
}
