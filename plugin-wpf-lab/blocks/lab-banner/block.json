{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 1,
  "name": "wpf/lab-banner",
  "title": "Lab — Banner page courante",
  "description": "Banner indiquant la méthode courante de la page (M1-M7). Direction B Lab.",
  "category": "widgets",
  "icon": "flag",
  "keywords": [
    "lab",
    "banner",
    "wpformation"
  ],
  "supports": {
    "autoRegister": true,
    "align": [
      "full"
    ]
  },
  "attributes": {
    "prefix": {
      "type": "string",
      "label": "Préfixe",
      "default": "VOUS CONSULTEZ ·"
    },
    "methodNum": {
      "type": "string",
      "label": "Numéro méthode (badge acid)",
      "default": "MÉTHODE 07"
    },
    "methodName": {
      "type": "string",
      "label": "Nom méthode",
      "default": "Blocs PHP custom (WP 7.0 autoRegister)"
    },
    "tag": {
      "type": "string",
      "label": "Tag droite",
      "default": "100% PHP"
    },
    "isFeatured": {
      "type": "boolean",
      "label": "Variante featured (fond acid)",
      "default": false
    }
  },
  "render": "file:./render.php",
  "style": "wpf-lab-blocks-style"
}
