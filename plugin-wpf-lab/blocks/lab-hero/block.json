{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 1,
  "name": "wpf/lab-hero",
  "title": "Lab — Hero",
  "description": "Hero brutalist Direction B Lab. Titre, sous-titre, eyebrow, 2 CTA. Édition par champs, design figé.",
  "category": "widgets",
  "icon": "megaphone",
  "keywords": [
    "lab",
    "hero",
    "wpformation"
  ],
  "supports": {
    "autoRegister": true,
    "anchor": true,
    "align": [
      "full"
    ],
    "spacing": {
      "margin": true,
      "padding": true
    }
  },
  "attributes": {
    "eyebrowTag": {
      "type": "string",
      "label": "Eyebrow — tag",
      "default": "FILE"
    },
    "eyebrowText": {
      "type": "string",
      "label": "Eyebrow — texte",
      "default": "methode-07-acf-php.md · POC ACF/PHP · 2026.05.21"
    },
    "titlePart1": {
      "type": "string",
      "label": "Titre — partie 1",
      "default": "Méthode 07 —"
    },
    "titleHighlight": {
      "type": "string",
      "label": "Titre — mot surligné (acid)",
      "default": "blocs PHP"
    },
    "titlePart2": {
      "type": "string",
      "label": "Titre — partie 2",
      "default": "× zéro JS"
    },
    "lead": {
      "type": "string",
      "label": "Sous-titre / lead",
      "default": "3 blocs Gutenberg custom écrits en PHP pur via Claude Code, avec UI auto-générée WP 7.0 (autoRegister). Design Direction B Lab locké, édition non-destructive par champs."
    },
    "ctaPrimaryLabel": {
      "type": "string",
      "label": "CTA primaire — texte",
      "default": "VOIR SECTION 2 ↘"
    },
    "ctaPrimaryUrl": {
      "type": "string",
      "label": "CTA primaire — URL",
      "default": "#sec2"
    },
    "ctaGhostLabel": {
      "type": "string",
      "label": "CTA secondaire — texte",
      "default": "RETOUR HUB"
    },
    "ctaGhostUrl": {
      "type": "string",
      "label": "CTA secondaire — URL",
      "default": "/"
    },
    "metaLine": {
      "type": "string",
      "label": "Ligne meta du bas",
      "default": "SECTION 1/3 · BLOCS PHP NATIFS · UI AUTOREGISTER · ZÉRO BUILD"
    }
  },
  "render": "file:./render.php",
  "style": "wpf-lab-blocks-style"
}
