{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 1,
  "name": "wpf/lab-hero",
  "title": "Lab — Hero",
  "description": "Hero brutalist Direction B Lab. Titre, sous-titre, eyebrow, 2 CTA. Édition par champs, design figé.",
  "category": "widgets",
  "icon": "megaphone",
  "keywords": ["lab", "hero", "wpformation"],
  "supports": {
    "autoRegister": true,
    "anchor": true,
    "align": ["full"],
    "spacing": { "margin": true, "padding": true }
  },
  "attributes": {
    "eyebrowTag": {
      "type": "string",
      "label": "Eyebrow — tag",
      "default": "FILE",
      "autoGenerateControl": true
    },
    "eyebrowText": {
      "type": "string",
      "label": "Eyebrow — texte",
      "default": "methode-07-acf-php.md · POC ACF/PHP · 2026.05.21",
      "autoGenerateControl": true
    },
    "titlePart1": {
      "type": "string",
      "label": "Titre — partie 1",
      "default": "Méthode 07 —",
      "autoGenerateControl": true
    },
    "titleHighlight": {
      "type": "string",
      "label": "Titre — mot surligné (acid)",
      "default": "blocs PHP",
      "autoGenerateControl": true
    },
    "titlePart2": {
      "type": "string",
      "label": "Titre — partie 2",
      "default": "× zéro JS",
      "autoGenerateControl": true
    },
    "lead": {
      "type": "string",
      "label": "Sous-titre / lead",
      "default": "3 blocs Gutenberg custom écrits en PHP pur via Claude Code, avec UI auto-générée WP 7.0 (autoGenerateControl). Design Direction B Lab locké, édition non-destructive par champs.",
      "autoGenerateControl": true
    },
    "ctaPrimaryLabel": {
      "type": "string",
      "label": "CTA primaire — texte",
      "default": "VOIR SECTION 2 ↘",
      "autoGenerateControl": true
    },
    "ctaPrimaryUrl": {
      "type": "string",
      "label": "CTA primaire — URL",
      "default": "#sec2",
      "autoGenerateControl": true
    },
    "ctaGhostLabel": {
      "type": "string",
      "label": "CTA secondaire — texte",
      "default": "RETOUR HUB",
      "autoGenerateControl": true
    },
    "ctaGhostUrl": {
      "type": "string",
      "label": "CTA secondaire — URL",
      "default": "/",
      "autoGenerateControl": true
    },
    "metaLine": {
      "type": "string",
      "label": "Ligne meta du bas",
      "default": "SECTION 1/3 · BLOCS PHP NATIFS · UI AUTOGENERATECONTROL · ZÉRO BUILD",
      "autoGenerateControl": true
    }
  },
  "render": "file:./render.php",
  "style": "wpf-lab-blocks-style"
}
