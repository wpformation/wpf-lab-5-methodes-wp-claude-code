{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 1,
  "name": "wpf/lab-cta-final",
  "title": "Lab — CTA final",
  "description": "CTA final Direction B Lab. Fond ink, titre bone avec accents acid + violet, 2 boutons.",
  "category": "widgets",
  "icon": "external",
  "keywords": [
    "lab",
    "cta",
    "wpformation"
  ],
  "supports": {
    "autoRegister": true,
    "anchor": true,
    "align": [
      "full"
    ],
    "spacing": {
      "margin": true,
      "padding": true
    }
  },
  "attributes": {
    "eyebrowText": {
      "type": "string",
      "label": "Eyebrow",
      "default": "SECTION 3/3 · VERDICT M7-A"
    },
    "titlePart1": {
      "type": "string",
      "label": "Titre — partie 1",
      "default": "Blocs PHP custom —"
    },
    "titleAcid": {
      "type": "string",
      "label": "Mot accent acid",
      "default": "design figé"
    },
    "titleSep": {
      "type": "string",
      "label": "Séparateur entre les 2 accents",
      "default": "×"
    },
    "titleViolet": {
      "type": "string",
      "label": "Mot accent violet",
      "default": "édition libre"
    },
    "titleEnd": {
      "type": "string",
      "label": "Fin de titre",
      "default": "."
    },
    "ctaPrimaryLabel": {
      "type": "string",
      "label": "CTA primaire — texte",
      "default": "VOIR LE HUB"
    },
    "ctaPrimaryUrl": {
      "type": "string",
      "label": "CTA primaire — URL",
      "default": "/"
    },
    "ctaGhostLabel": {
      "type": "string",
      "label": "CTA secondaire — texte",
      "default": "RELIRE SECTION 2"
    },
    "ctaGhostUrl": {
      "type": "string",
      "label": "CTA secondaire — URL",
      "default": "#sec2"
    },
    "metaLine": {
      "type": "string",
      "label": "Ligne meta du bas",
      "default": "3 blocs PHP custom · 0 dépendance plugin tierce · 0 JS / 0 build · WP 7.0 autoRegister"
    }
  },
  "render": "file:./render.php",
  "style": "wpf-lab-blocks-style"
}
